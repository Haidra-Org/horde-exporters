      "targets": [{ "expr": "horde_model_workers_count{model=~\"$model\", type=\"image\"} / ignoring(model) group_left horde_models_workers_count{type=\"image\"}", "legendFormat": "", "refId": "A" }],
      "title": "% of Image Workers",
      "type": "stat"
