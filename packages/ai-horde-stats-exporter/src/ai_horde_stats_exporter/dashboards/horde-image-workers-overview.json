      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 25 },
      "id": 31,
      "options": { "legend": { "calcs": ["lastNotNull", "mean"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [{ "expr": "topk(15, horde_worker_requests_fulfilled_total{type=\"image\"})", "legendFormat": "{{worker}}", "refId": "A" }],
      "title": "Requests Fulfilled by Worker",
