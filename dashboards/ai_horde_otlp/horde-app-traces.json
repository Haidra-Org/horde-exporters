{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "RED metrics (Rate, Errors, Duration) for AI Horde hot paths, sourced from OTLP histograms emitted by horde/telemetry.py and the webhook / background-job counters.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "asDropdown": true,
      "icon": "external link",
      "includeVars": true,
      "keepTime": true,
      "tags": ["horde"],
      "targetBlank": false,
      "title": "Horde Dashboards",
      "type": "dashboards"
    }
  ],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Request latency (p50 / p95 / p99)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "id": 1,
      "title": "/generate (by gentype)",
      "type": "timeseries",
      "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "palette-classic" } }, "overrides": [] },
      "options": { "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true } },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (horde_gentype) (rate(horde_generate_duration[$__rate_interval])))",
          "legendFormat": "p50 {{horde_gentype}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (horde_gentype) (rate(horde_generate_duration[$__rate_interval])))",
          "legendFormat": "p95 {{horde_gentype}}",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (horde_gentype) (rate(horde_generate_duration[$__rate_interval])))",
          "legendFormat": "p99 {{horde_gentype}}",
          "refId": "C"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 },
      "id": 2,
      "title": "/generate/pop",
      "type": "timeseries",
      "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "palette-classic" } }, "overrides": [] },
      "options": { "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true } },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(horde_pop_duration[$__rate_interval])))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum(rate(horde_pop_duration[$__rate_interval])))", "legendFormat": "p95", "refId": "B" },
        { "expr": "histogram_quantile(0.99, sum(rate(horde_pop_duration[$__rate_interval])))", "legendFormat": "p99", "refId": "C" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "id": 3,
      "title": "/generate/submit",
      "type": "timeseries",
      "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "palette-classic" } }, "overrides": [] },
      "options": { "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true } },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(horde_submit_duration[$__rate_interval])))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum(rate(horde_submit_duration[$__rate_interval])))", "legendFormat": "p95", "refId": "B" },
        { "expr": "histogram_quantile(0.99, sum(rate(horde_submit_duration[$__rate_interval])))", "legendFormat": "p99", "refId": "C" }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 101,
      "title": "Pop diagnostics",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 10 },
      "id": 10,
      "title": "WP query p95 (DB)",
      "type": "timeseries",
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(horde_pop_wp_query_duration[$__rate_interval])))", "legendFormat": "p95", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 10 },
      "id": 11,
      "title": "Candidates evaluated per pop",
      "type": "timeseries",
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(horde_pop_candidates_evaluated[$__rate_interval])))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum(rate(horde_pop_candidates_evaluated[$__rate_interval])))", "legendFormat": "p95", "refId": "B" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 10 },
      "id": 12,
      "title": "Pop skip reasons (per second)",
      "type": "timeseries",
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        { "expr": "sum by (reason) (rate(horde_pop_skipped_total[$__rate_interval]))", "legendFormat": "{{reason}}", "refId": "A" }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 },
      "id": 102,
      "title": "Webhook reliability",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 18 },
      "id": 20,
      "title": "Webhook attempt outcomes (per second)",
      "type": "timeseries",
      "fieldConfig": { "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } }, "overrides": [] },
      "targets": [
        { "expr": "sum by (outcome) (rate(horde_webhook_outcomes_total[$__rate_interval]))", "legendFormat": "{{outcome}}", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 18 },
      "id": 21,
      "title": "Webhook attempt duration",
      "type": "timeseries",
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum by (outcome) (rate(horde_webhook_attempt_duration[$__rate_interval])))", "legendFormat": "p95 {{outcome}}", "refId": "A" }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 25 },
      "id": 103,
      "title": "Background jobs (PrimaryTimedFunction)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 26 },
      "id": 30,
      "title": "Job duration p95 (by job)",
      "type": "timeseries",
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum by (horde_job_name) (rate(horde_job_duration[$__rate_interval])))", "legendFormat": "{{horde_job_name}}", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 26 },
      "id": 31,
      "title": "Job failures (per second)",
      "type": "timeseries",
      "fieldConfig": { "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" } }, "overrides": [] },
      "targets": [
        { "expr": "sum by (horde_job_name) (rate(horde_job_failures_total[$__rate_interval]))", "legendFormat": "{{horde_job_name}}", "refId": "A" }
      ]
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 34 },
      "id": 104,
      "title": "Countermeasures & submissions",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 35 },
      "id": 40,
      "title": "IP-check duration p95",
      "type": "timeseries",
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(horde_countermeasures_ip_check_duration[$__rate_interval])))", "legendFormat": "p95", "refId": "A" }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 35 },
      "id": 41,
      "title": "Submit kudos distribution p50/p95",
      "type": "timeseries",
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(horde_submit_kudos[$__rate_interval])))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum(rate(horde_submit_kudos[$__rate_interval])))", "legendFormat": "p95", "refId": "B" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 60 },
      "id": 105,
      "title": "Service Graph & Request Funnel (Tempo metrics-generator)",
      "type": "row"
    },
    {
      "datasource": { "type": "tempo", "uid": "tempo" },
      "description": "Service graph derived from traces. Cap query interval to ≤24h — the ai-horde-telemetry tenant has 3-day retention.",
      "gridPos": { "h": 12, "w": 12, "x": 0, "y": 61 },
      "id": 30,
      "options": { "edges": { "mainStatUnit": "ms" }, "nodes": { "mainStatUnit": "short" } },
      "targets": [{ "queryType": "serviceMap", "serviceMapQuery": "{}", "refId": "A" }],
      "title": "Service Graph",
      "type": "nodeGraph"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Request funnel via Tempo span-metrics generator: generate → pop → submit. Compare rates to spot stage-level bottlenecks.",
      "gridPos": { "h": 6, "w": 4, "x": 12, "y": 61 },
      "id": 31,
      "fieldConfig": { "defaults": { "color": { "fixedColor": "blue", "mode": "fixed" }, "unit": "ops" }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["mean"], "fields": "", "values": false }, "orientation": "auto", "textMode": "auto", "colorMode": "background", "graphMode": "area" },
      "targets": [{ "expr": "sum(rate(traces_spanmetrics_calls_total{service_name=\"ai-horde\", span_name=~\".*generate.*\"}[5m]))", "legendFormat": "/generate", "refId": "A" }],
      "title": "/generate (rate)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 6, "w": 4, "x": 16, "y": 61 },
      "id": 32,
      "fieldConfig": { "defaults": { "color": { "fixedColor": "purple", "mode": "fixed" }, "unit": "ops" }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["mean"], "fields": "", "values": false }, "orientation": "auto", "textMode": "auto", "colorMode": "background", "graphMode": "area" },
      "targets": [{ "expr": "sum(rate(traces_spanmetrics_calls_total{service_name=\"ai-horde\", span_name=~\".*pop.*\"}[5m]))", "legendFormat": "/pop", "refId": "A" }],
      "title": "/pop (rate)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 6, "w": 4, "x": 20, "y": 61 },
      "id": 33,
      "fieldConfig": { "defaults": { "color": { "fixedColor": "green", "mode": "fixed" }, "unit": "ops" }, "overrides": [] },
      "options": { "reduceOptions": { "calcs": ["mean"], "fields": "", "values": false }, "orientation": "auto", "textMode": "auto", "colorMode": "background", "graphMode": "area" },
      "targets": [{ "expr": "sum(rate(traces_spanmetrics_calls_total{service_name=\"ai-horde\", span_name=~\".*submit.*\"}[5m]))", "legendFormat": "/submit", "refId": "A" }],
      "title": "/submit (rate)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "description": "Combined funnel trend over time. Prefer time ranges ≤ 24h (telemetry tenant retention is 3d).",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 67 },
      "id": 34,
      "type": "timeseries",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "ops",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 2, "fillOpacity": 10, "gradientMode": "none", "showPoints": "never", "spanNulls": true, "stacking": { "group": "A", "mode": "none" }, "thresholdsStyle": { "mode": "off" } }
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["lastNotNull", "mean"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        { "expr": "sum(rate(traces_spanmetrics_calls_total{service_name=\"ai-horde\", span_name=~\".*generate.*\"}[$__rate_interval]))", "legendFormat": "/generate", "refId": "A" },
        { "expr": "sum(rate(traces_spanmetrics_calls_total{service_name=\"ai-horde\", span_name=~\".*pop.*\"}[$__rate_interval]))", "legendFormat": "/pop", "refId": "B" },
        { "expr": "sum(rate(traces_spanmetrics_calls_total{service_name=\"ai-horde\", span_name=~\".*submit.*\"}[$__rate_interval]))", "legendFormat": "/submit", "refId": "C" }
      ],
      "title": "Funnel Trend (rate)"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["horde", "ai-horde", "otlp", "traces"],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "label": "Data Source",
        "type": "datasource",
        "query": "prometheus",
        "refresh": 1,
        "regex": "",
        "multi": false,
        "includeAll": false,
        "description": "Defaults to the Telemetry tenant where OTLP-sourced histograms (horde_*_duration, http_server_duration) and Tempo-derived span metrics live; switch to AI Horde App if you've routed OTLP exports to a different tenant.",
        "current": {
          "selected": false,
          "text": "Telemetry",
          "value": "mimir-telemetry"
        }
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Horde App Traces (OTLP RED)",
  "uid": "horde-app-traces",
  "version": 2
}
