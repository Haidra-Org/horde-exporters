{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "AI Horde Operations Overview — single-pane: active alerts + app health (mimir-app + mimir-telemetry) + worker drop signals + Postgres saturation + host top-N + Loki critical/error logs. Org 1 only (no public variant).",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "asDropdown": true,
      "icon": "external link",
      "includeVars": true,
      "keepTime": true,
      "tags": ["horde"],
      "targetBlank": false,
      "title": "Horde Dashboards",
      "type": "dashboards"
    }
  ],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Active Alerts",
      "type": "row"
    },
    {
      "datasource": { "type": "alertmanager", "uid": "alertmanager" },
      "description": "All firing/pending alerts at warning or critical severity. Single-pane source of truth for current incidents.",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "alertInstanceLabelFilter": "{severity=~\"critical|warning\"}",
        "alertName": "",
        "dashboardAlerts": false,
        "groupBy": ["alertname"],
        "groupMode": "custom",
        "maxItems": 50,
        "showInactiveAlerts": false,
        "sortOrder": 3,
        "stateFilter": {
          "firing": true,
          "pending": true,
          "noData": false,
          "normal": false,
          "error": true
        },
        "viewMode": "list"
      },
      "title": "Firing & Pending Alerts",
      "type": "alertlist"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 110,
      "title": "Application Health",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "mimir-app" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "color": "red", "text": "DOWN" }, "1": { "color": "green", "text": "UP" } }, "type": "value" }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 4, "x": 0, "y": 10 },
      "id": 111,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "orientation": "auto", "textMode": "auto", "colorMode": "background", "graphMode": "none" },
      "targets": [{ "expr": "horde_api_up", "legendFormat": "", "refId": "A", "instant": true }],
      "title": "API Up",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "mimir-app" },
      "description": "Estimated time to drain the image queue at current throughput.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 300 }, { "color": "red", "value": 1800 }] },
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 5, "x": 4, "y": 10 },
      "id": 112,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "orientation": "auto", "textMode": "auto", "colorMode": "background", "graphMode": "area" },
      "targets": [{ "expr": "horde_performance_estimated_queue_drain_seconds{type=\"image\"}", "legendFormat": "", "refId": "A" }],
      "title": "Image Queue Drain",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "mimir-telemetry" },
      "description": "p95 latency of POST /generate by gentype. Threshold matches HordeGenerateLatencyHigh (>2s).",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "none",
            "showPoints": "never",
            "spanNulls": true,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "line" }
          },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 2.0 }] }
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 8, "x": 9, "y": 10 },
      "id": 113,
      "options": {
        "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [{ "expr": "histogram_quantile(0.95, sum by (le, horde_gentype) (rate(horde_generate_duration_bucket[$__rate_interval])))", "legendFormat": "{{horde_gentype}}", "refId": "A" }],
      "title": "/generate p95 Latency by gentype",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "mimir-telemetry" },
      "description": "p95 latency of /generate/pop. Threshold matches HordePopLatencyHigh (>1s).",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "none",
            "showPoints": "never",
            "spanNulls": true,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "line" }
          },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1.0 }] }
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 7, "x": 17, "y": 10 },
      "id": 114,
      "options": {
        "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "targets": [{ "expr": "histogram_quantile(0.95, sum by (le) (rate(horde_pop_duration_bucket[$__rate_interval])))", "legendFormat": "p95", "refId": "A" }],
      "title": "/generate/pop p95 Latency",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 16 },
      "id": 120,
      "title": "Submit Outcomes & Worker Drop",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "mimir-telemetry" },
      "description": "Submit outcome rate by category. Sustained censored/faulted indicates abuse, worker quality, or model failures.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 1,
            "fillOpacity": 25,
            "gradientMode": "opacity",
            "showPoints": "never",
            "spanNulls": true,
            "stacking": { "group": "A", "mode": "normal" },
            "thresholdsStyle": { "mode": "off" }
          }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "accepted" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }] },
          { "matcher": { "id": "byName", "options": "censored" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }] },
          { "matcher": { "id": "byName", "options": "faulted" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }] },
          { "matcher": { "id": "byName", "options": "error" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "dark-red" } }] }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 17 },
      "id": 121,
      "options": {
        "legend": { "calcs": ["lastNotNull", "mean"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [{ "expr": "sum by (horde_outcome) (rate(horde_submit_outcomes_total[$__rate_interval]))", "legendFormat": "{{horde_outcome}}", "refId": "A" }],
      "title": "Submit Outcome Rate (stacked)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "mimir-app" },
      "description": "Worker count vs 30 minutes ago. Below 0.5 matches HordeImageWorkerCountDrop alert.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "percentunit",
          "min": 0,
          "max": 1.5,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "none",
            "showPoints": "never",
            "spanNulls": true,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "line" }
          },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 0.5 }] }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 17 },
      "id": 122,
      "options": {
        "legend": { "calcs": ["lastNotNull"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        { "expr": "horde_performance_worker_count{type=\"image\"} / clamp_min(horde_performance_worker_count{type=\"image\"} offset 30m, 1)", "legendFormat": "Image (vs 30m ago)", "refId": "A" },
        { "expr": "horde_performance_worker_count{type=\"text\"} / clamp_min(horde_performance_worker_count{type=\"text\"} offset 30m, 1)", "legendFormat": "Text (vs 30m ago)", "refId": "B" }
      ],
      "title": "Worker Count vs 30m Ago",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 25 },
      "id": 160,
      "title": "Pop Diagnostics & Suspicion Logs",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "mimir-telemetry" },
      "description": "Job-pop skip rate by reason. Domain-wide (not filtered by worker).",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 1,
            "fillOpacity": 25,
            "gradientMode": "opacity",
            "showPoints": "never",
            "spanNulls": true,
            "stacking": { "group": "A", "mode": "normal" },
            "thresholdsStyle": { "mode": "off" }
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 26 },
      "id": 161,
      "options": {
        "legend": { "calcs": ["lastNotNull", "mean"], "displayMode": "table", "placement": "right", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [{ "expr": "sum by (horde_skip_reason) (rate(horde_pop_skipped_total[$__rate_interval]))", "legendFormat": "{{horde_skip_reason}}", "refId": "A" }],
      "title": "Skips per Second by Reason",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "mimir-telemetry" },
      "description": "Top 10 skip reasons over the last hour.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 26 },
      "id": 162,
      "options": {
        "showHeader": true,
        "sortBy": [{ "desc": true, "displayName": "Count" }],
        "cellHeight": "sm",
        "footer": { "show": false }
      },
      "targets": [{ "expr": "topk(10, sum by (horde_skip_reason) (increase(horde_pop_skipped_total[1h])))", "legendFormat": "", "refId": "A", "instant": true, "format": "table" }],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "__name__": true, "instance": true, "job": true },
            "renameByName": { "horde_skip_reason": "Skip Reason", "Value": "Count" }
          }
        }
      ],
      "title": "Top Skip Reasons (1h)",
      "type": "table"
    },
    {
      "datasource": { "type": "loki", "uid": "loki-app" },
      "description": "Recent worker auto-pause / suspicion log lines from the AI-Horde app.",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 34 },
      "id": 163,
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      },
      "targets": [{ "expr": "{app=\"ai-horde\"} |= \"suspicion increased\"", "refId": "A" }],
      "title": "Recent Worker Suspicion Lines",
      "type": "logs"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 44 },
      "id": 130,
      "title": "Postgres Saturation",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "mimir-app" },
      "description": "Connection saturation as % of max_connections. Requires postgres_exporter (see horde_monitoring_install_postgres_alerts).",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 60 }, { "color": "red", "value": 90 }] },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 25,
            "gradientMode": "scheme",
            "showPoints": "never",
            "spanNulls": true,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "line+area" }
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 45 },
      "id": 131,
      "options": {
        "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [{ "expr": "100 * sum by (instance) (pg_stat_activity_count) / clamp_min(sum by (instance) (pg_settings_max_connections), 1)", "legendFormat": "{{instance}}", "refId": "A" }],
      "title": "PG Connection Saturation %",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "mimir-app" },
      "description": "Age of oldest open transaction. Requires the pg_horde_long_tx custom query.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "s",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 60 }, { "color": "red", "value": 600 }] },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "none",
            "showPoints": "never",
            "spanNulls": true,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "line" }
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 45 },
      "id": 132,
      "options": {
        "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "targets": [{ "expr": "pg_horde_long_tx_oldest_seconds", "legendFormat": "oldest tx", "refId": "A" }],
      "title": "Oldest Open Transaction",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "mimir-app" },
      "description": "Postgres deadlocks per 5 minutes.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 1 }, { "color": "red", "value": 5 }] },
          "custom": {
            "drawStyle": "bars",
            "lineWidth": 1,
            "fillOpacity": 50,
            "gradientMode": "none",
            "showPoints": "never",
            "spanNulls": false,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "off" }
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 45 },
      "id": 133,
      "options": {
        "legend": { "calcs": ["sum", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [{ "expr": "increase(pg_stat_database_deadlocks{datname=~\"horde.*\"}[5m])", "legendFormat": "{{datname}}", "refId": "A" }],
      "title": "PG Deadlocks (5m)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "mimir-telemetry" },
      "description": "Rate of SQLAlchemy QueuePool TimeoutError occurrences. Requires AI-Horde with horde.db.pool.timeout counter.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "ops",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 0.01 }, { "color": "red", "value": 0.1 }] },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 25,
            "gradientMode": "scheme",
            "showPoints": "never",
            "spanNulls": true,
            "stacking": { "group": "A", "mode": "none" },
            "thresholdsStyle": { "mode": "line+area" }
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 51 },
      "id": 134,
      "options": {
        "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "targets": [{ "expr": "sum(rate(horde_db_pool_timeout_total[$__rate_interval]))", "legendFormat": "pool timeouts/s", "refId": "A" }],
      "title": "DB Pool Timeouts (rate)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 57 },
      "id": 140,
      "title": "Host Top-N",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "mimir-infra" },
